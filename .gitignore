# Node
node_modules/

# Disk images — 50GB+ raw SD clones. GitHub hard-blocks files over 100MB.
# Jetson2G_SEA_APRILTAG_250422.img is also a SEA/AprilTag build, unrelated to
# this workshop. Keep these out of git entirely; they are not versionable.
*.img
*.img.gz
*.img.xz

# Secrets
.env
.env.*

# Local AI-tooling setup (claude-flow / ruflo). Kept on disk, kept out of the
# repo: this project is followed along by hand and needs none of it.
.claude/
.claude-flow/
.swarm/
CLAUDE.md
.mcp.json
.env.example
config/
package.json
package-lock.json
docs/claude-flow/
scripts/claude-with-env.sh
scripts/claude-with-env.ps1
# Generic claude-flow starter templates copied in for reference. Tooling, not
# part of this project.
references/claude-flow-starter-unix-version/
references/claude-flow-starter-windows-version/

# Upstream NVIDIA Jetson material copied in for reference (~140MB). Not ours to
# version, and far too large to belong in this repo.
references/nvidia-jetson/

# A sibling workshop (kevincho417/edge_voice_assistant) cloned in for reference:
# a Jetson Nano 4GB *voice* assistant, useful as house style. It is a nested git
# clone with its own .git, so committing it would leave a broken gitlink. It is
# reference only and does not bind this project's design — see
# docs/01-design/06-deployment-topology-edge-relay.md.
references/edge_voice_assistant/

